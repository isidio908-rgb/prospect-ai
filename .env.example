# Docker Compose local environment
# Copy this file to .env and replace every secret before starting the stack.

POSTGRES_USER=prospect_user
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_DB=prospect_ai

# Prefer a fixed Evolution API tag instead of latest when you choose a production baseline.
EVOLUTION_API_IMAGE=evoapicloud/evolution-api:latest
EVOLUTION_API_GLOBAL_KEY=replace-with-a-strong-random-api-key
EVOLUTION_WEBHOOK_URL=https://your-public-domain.com/api/whatsapp/webhook
EVOLUTION_WEBHOOK_SECRET=replace-with-a-strong-random-webhook-secret

JWT_SECRET=replace-with-a-strong-random-jwt-secret
# Must be 64 hex characters for AES-256 style key material.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# Autopilot 2.0 daemon
# When enabled, active automation rules run periodically and approved messages are processed.
AUTOPILOT_DAEMON_ENABLED=true
AUTOPILOT_DAEMON_CRON=*/5 * * * *
AUTOPILOT_DAEMON_SCHEDULER_LIMIT=50
AUTOPILOT_DAEMON_WORKER_LIMIT=10

# Lead collection provider
RAPIDAPI_KEY=
RAPIDAPI_HOST=local-business-data.p.rapidapi.com
RAPIDAPI_PROVIDER_NAME=letscrape_local_business_data
RAPIDAPI_DAILY_LIMIT=100

# Use placeholders: {query}, {city}, {niche}, {limit}, {lat}, {lng}, {zoom}, {region}, {language}, {extractEmailsAndContacts}
# Exemplo abaixo aponta para o endpoint /search da Local Business Data (RapidAPI).
# Troque pelo formato do provider escolhido caso use outro.
RAPIDAPI_SEARCH_URL=https://local-business-data.p.rapidapi.com/search?query={query}&limit={limit}&lat={lat}&lng={lng}&zoom={zoom}&language={language}&region={region}&extract_emails_and_contacts={extractEmailsAndContacts}
