# Configurações do Sistema (NÃO coloque credenciais RapidAPI aqui!)
# As credenciais RapidAPI são configuradas por usuário via Front-end

# Banco de Dados
DATABASE_URL=postgresql://prospect_user:prospect_pass@localhost:5432/prospect_ai

# Autenticação
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Criptografia (para API Keys)
ENCRYPTION_KEY=change-this-to-a-64-char-hex-string-in-production

# Servidor
PORT=3001
NODE_ENV=development

# CORS (Front-end URL)
FRONTEND_URL=http://localhost:5173

# Evolution API (integração WhatsApp)
# URL interna do servidor Evolution API (self-hosted via Docker, ver docker-compose.yml)
EVOLUTION_API_URL=http://localhost:8080
# Chave global de administração da Evolution API (cria/gerencia instâncias). Gere com: openssl rand -hex 32
EVOLUTION_API_GLOBAL_KEY=change-this-to-a-secure-random-string-in-production
# URL pública que a Evolution API vai chamar para entregar eventos (mensagens, QR code, status).
# Em desenvolvimento local, use um tunnel (ex: ngrok) apontando para /api/whatsapp/webhook
EVOLUTION_WEBHOOK_URL=https://your-public-domain.com/api/whatsapp/webhook
# Segredo enviado no header Authorization do webhook, para validar que a chamada vem da Evolution API
EVOLUTION_WEBHOOK_SECRET=change-this-to-a-secure-random-string-in-production
